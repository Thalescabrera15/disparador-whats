# ===========================================================================
# dispatch-engine - variaveis de ambiente (copie para .env e preencha)
# Bancos: usar instancias ISOLADAS no Railway (nada compartilhado com Verttex)
# ===========================================================================

# --- Infra (Railway) ---
DATABASE_URL="postgresql://user:pass@host:5432/dispatch?schema=public"
REDIS_URL="redis://default:pass@host:6379"

# --- API Core ---
NODE_ENV=development
CORE_PORT=3000
JWT_SECRET="troque-este-segredo-grande-e-aleatorio"
JWT_EXPIRES_IN="12h"
# DEV apenas: parear chip sem proxy. NUNCA true em producao (anti-ban exige proxy estavel).
ALLOW_PAIR_WITHOUT_PROXY=false

# --- Seed do admin inicial (usado por `pnpm db:seed`) ---
ADMIN_EMAIL="anacleto.thalescabrera@gmail.com"
ADMIN_PASSWORD="troque-esta-senha"

# --- LLM (IA conversacional) ---
ANTHROPIC_API_KEY=""
# Venice AI (OpenAI-compativel, sem censura). Quando QWEN_BASE_URL for venice.ai,
# o adapter injeta venice_parameters (include_venice_system_prompt=false + strip_thinking).
AI_ADAPTER=stub                # 'stub' (offline) ou 'qwen' (usa o endpoint abaixo)
QWEN_BASE_URL="https://api.venice.ai/api/v1"
QWEN_API_KEY=""                # sua API key da Venice
QWEN_MODEL="e2ee-qwen3-6-35b-a3b-uncensored-p" # Qwen3.6 35B A3B Uncensored (128K)
AI_TEMPERATURE=0.4
# Qwen3 é modelo de RACIOCÍNIO (~800 tok/turno antes da resposta) -> teto alto.
# Modelo sem raciocínio (ex: venice-uncensored): 400 basta.
AI_MAX_TOKENS=2000

# --- Transcricao / TTS ---
WHISPER_URL=""
ELEVENLABS_API_KEY=""          # opcional

# --- Storage de midia (Cloudflare R2 ou equivalente) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY=""
R2_SECRET=""
R2_BUCKET=""

# --- Defaults de envio / anti-ban ---
DEFAULT_DAILY_CAP=55
DEFAULT_WINDOW_START=9
DEFAULT_WINDOW_END=20
RAMP_CURVE="5,8,15,25,35,45,55"
JITTER_MIN_MS=45000
JITTER_MAX_MS=180000
OPTOUT_KEYWORDS="sair,parar,pare,descadastrar,nao quero,não quero,stop,cancelar"
